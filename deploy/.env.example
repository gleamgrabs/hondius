# ─── Hondius Watch — production env ───────────────────────────────
# Place at /opt/hondius/.env on the server. Mode 600.

# Public canonical URL (used in OG, sitemap, email links)
NEXT_PUBLIC_SITE_URL=https://hondius-watch.com

# Resend (https://resend.com) — transactional + broadcast email
# Free: 3,000 emails/mo, 100/day. Verify your sending domain first.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Hondius Watch <updates@hondius-watch.com>

# Long random secret (use: `openssl rand -hex 32`).
# Required to call POST /api/broadcast — protects newsletter sending.
BROADCAST_ADMIN_TOKEN=replace_me_with_openssl_rand_hex_32

# Cloudflare Tunnel token — connects this container to Cloudflare's edge
# without binding any host port. Get it from:
#   https://one.dash.cloudflare.com → Networks → Tunnels → Create a tunnel
#   → name: "hondius" → choose "Cloudflared" → copy token
# (One single string, starts with `eyJ...`)
CLOUDFLARE_TUNNEL_TOKEN=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token for /api/internal/ingest — used by GitHub Actions news poller.
# `openssl rand -hex 32`
INGEST_TOKEN=replace_me_with_openssl_rand_hex_32

# Token for /admin?token=… UI and /api/admin/* endpoints.
# Can be same as BROADCAST_ADMIN_TOKEN, but a separate one is cleaner.
# `openssl rand -hex 32`
ADMIN_TOKEN=replace_me_with_openssl_rand_hex_32

# Plausible analytics — leave UNSET to disable script injection.
# Set to your verified domain in Plausible dashboard (e.g. "hondius-watch.com").
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=hondius-watch.com

# Anthropic API key for LLM case extraction.
# When set, each new event auto-published by the RSS parser is sent to Claude Haiku
# which extracts structured case data (country, count, status) and auto-publishes
# map markers. Without it, the parser only ingests events; cases are manual.
# Get key at https://console.anthropic.com → API Keys.
# Cost: ~$0.001 per article, typically <$0.10/month at current news volume.
# This key is only used in GitHub Actions (workflow secret) — not in the running app.
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ── AIS live ship position (optional) ──────────────────────────────
# Free signup at https://aisstream.io → API Keys → Create.
# Without these, the map shows interpolated ship animation along the planned route.
# With these, the map shows the actual MV Hondius position from AIS broadcasts.
# Run with: docker compose --profile ais up -d
# AIS_API_KEY=your_aisstream_io_key
# MV_HONDIUS_MMSI=246351000
